[gd_scene format=3 uid="uid://cirurbwcikblj"]

[sub_resource type="GDScript" id="GDScript_si7xh"]
script/source = "extends SceneTree

const HEARTBEAT_TIMEOUT := 3.0
const TICK_RATE := 0.1

var peer: ENetMultiplayerPeer
var connected_clients := {} # peer_id -> time since last heartbeat
var accumulator := 0.0


func _init():
	peer = ENetMultiplayerPeer.new()
	var err = peer.create_server(9000)

	if err != OK:
		print(\"Failed to start server:\", err)
		quit()
		return

	print(\"Server started on port 9000\")


func _iteration(delta: float) -> bool:
	if peer == null:
		return true

	peer.poll()

	# -------------------------
	# HANDLE INCOMING PACKETS
	# -------------------------
	while peer.get_available_packet_count() > 0:
		var client_id := peer.get_packet_peer()
		var packet := peer.get_packet().get_string_from_utf8()

		_handle_packet(client_id, packet)

	# -------------------------
	# HEARTBEATS (manual timer)
	# -------------------------
	accumulator += delta
	if accumulator >= TICK_RATE:
		accumulator = 0.0
		_check_heartbeats()

	return true


func _handle_packet(client_id: int, packet: String):
	print(\"PACKET from\", client_id, \":\", packet)

	if packet.begins_with(\"handshake:\"):
		if not connected_clients.has(client_id):
			print(\"Client connected:\", client_id)

		connected_clients[client_id] = 0.0
		_send(client_id, \"handshake_ack:%d\" % client_id)

	elif packet.begins_with(\"heartbeat:\"):
		if connected_clients.has(client_id):
			connected_clients[client_id] = 0.0


func _check_heartbeats():
	for client_id in connected_clients.keys().duplicate():
		connected_clients[client_id] += TICK_RATE

		if connected_clients[client_id] > HEARTBEAT_TIMEOUT:
			print(\"Client timed out:\", client_id)
			remove_client(client_id)


func remove_client(client_id: int):
	if connected_clients.has(client_id):
		connected_clients.erase(client_id)

	broadcast(\"remove:%d\" % client_id)


func broadcast(message: String):
	for peer_id in connected_clients.keys():
		_send(peer_id, message)


func _send(peer_id: int, message: String):
	peer.set_target_peer(peer_id)
	peer.put_packet(message.to_utf8_buffer())
"

